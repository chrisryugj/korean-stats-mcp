{
  "name": "korean-stats-mcp",
  "version": "1.7.1",
  "description": "한국 통계청 KOSIS OpenAPI 기반 MCP 서버 - 91개 키워드 + 100+ 자연어 별칭/오타 정규화 + 17개 시도/자치구 230+ 라우팅 + 시계열 추세 + 체인 도구 3종(지역 브리핑·다지역 비교·정책 영역) + 자치구 정밀 OpenAPI 라우팅 (인구·출산·고령·의사·주거·고용·실업·인구동태 14종 통계표 전국 자치구).",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "korean-stats-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "inspector": "tsc && npx @modelcontextprotocol/inspector dist/index.js",
    "test": "tsc && playwright test",
    "test:ui": "tsc && playwright test --ui",
    "test:headed": "tsc && playwright test --headed",
    "sim": "tsc && node scripts/simulate-realworld-100.mjs && node scripts/simulate-district-routing.mjs && node scripts/simulate-nationwide.mjs && node scripts/simulate-edge-cases.mjs && node scripts/simulate-chains.mjs",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src/**/*.ts"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "kosis",
    "statistics",
    "korea",
    "openapi",
    "ai",
    "llm"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "dotenv": "^16.4.5",
    "express": "^4.22.2",
    "kordoc": "^2.8.0",
    "node-cache": "^5.1.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/express": "^4.17.25",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "@vercel/node": "^3.0.0",
    "eslint": "^8.56.0",
    "prettier": "^3.2.4",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "comment": "보안 패치 강제 — 전부 transitive 의존성. ajv는 7+만 타겟(ESLint의 ajv 6 보존).",
    "overrides": {
      "path-to-regexp": "^8.4.0",
      "fast-uri": "^3.1.2",
      "ajv@>=7.0.0": "^8.18.0",
      "qs": "^6.14.2",
      "protobufjs": "^7.5.8"
    }
  }
}
